# ══════════════════════════════════════════════════
# mangaFactory Backend — Environment Variables
# ══════════════════════════════════════════════════
# Copy this file to .env and fill in your values.

# ── Neon PostgreSQL (Serverless) ──────────────────
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.region.aws.neon.tech/mangafactory?sslmode=require

# ── Clerk Authentication ──────────────────────────
CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json

# ── Cloudflare R2 (S3-compatible Storage) ─────────
# Endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=mangafactory
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── Stripe Payments ───────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ── App ───────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
