# ══════════════════════════════════════════════════════════════
# MangaLabTH — Full-Stack Environment Variables
# ══════════════════════════════════════════════════════════════
# This file contains ALL environment variables for the unified
# full-stack deployment (Next.js + FastAPI in one container).
#
# Copy to .env.fullstack and fill in your values.
# For Cloud Run: set these as "Environment Variables" in the console.
# ══════════════════════════════════════════════════════════════

# ── Supabase PostgreSQL ───────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@aws-0-region.pooler.supabase.com:5432/postgres

# ── Clerk Authentication ──────────────────────────
# Backend uses these for JWT verification
CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json
PRIMARY_ADMIN_EMAIL=your_admin_email@example.com

# Frontend also needs CLERK_SECRET_KEY (same value as above, set once)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY is set at BUILD TIME via --build-arg

# ── Cloudflare R2 (S3-compatible Storage) ─────────
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=factory-manga-storage
R2_PUBLIC_URL=https://cdn.mangalab-th.com

# ── FeelFreePay Payments ──────────────────────────
FFP_CUSTOMER_KEY=your_ffp_customer_key
FFP_PUBLIC_KEY=your_ffp_public_key
FFP_SECRET_KEY=your_ffp_secret_key
FFP_BASE_URL=https://api.feelfreepay.com

# ── Email Service (Brevo) ─────────────────────────
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="MangaLabTH <support@mangalab-th.com>"

# ── App Config ────────────────────────────────────
APP_ENV=production
SITE_URL=https://mangalab-th.com
FRONTEND_URL=https://mangalab-th.com
INTERNAL_FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=https://mangalab-th.com
REVALIDATION_SECRET=mangalabth-prod-secret-2026

# ── Frontend Runtime Vars ─────────────────────────
# These are read at runtime by Next.js server
NEXT_PUBLIC_SITE_URL=https://mangalab-th.com
NEXT_PUBLIC_R2_PUBLIC_URL=https://cdn.mangalab-th.com
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Build-Time Only (pass via --build-arg) ────────
# These NEXT_PUBLIC_* vars are embedded during `npm run build`
# Set them in Cloud Build substitutions, NOT as runtime env vars:
#   NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxx
#   NEXT_PUBLIC_GA_MEASUREMENT_ID=G-xxxx

# ── Internal (DO NOT CHANGE) ─────────────────────
# INTERNAL_API_URL is used by Next.js server to call FastAPI internally
INTERNAL_API_URL=http://localhost:8000/api/v1
